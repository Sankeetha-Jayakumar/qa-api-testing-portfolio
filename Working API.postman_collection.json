				{
					"name": "Get the created user",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"verify status code 200\", function(){",
									"    pm.response.to.have.status(200)",
									"});",
									"",
									"pm.test(\"Verify status code using expect\", function(){",
									"    pm.expect(pm.response.code).to.eql(200)",
									"});",
									"pm.test(\"Assert status message OK\", ()=>{",
									"    pm.response.to.have.status(\"OK\")",
									"});",
									"pm.test(\"Assert OK using expect\", ()=>{",
									"    pm.expect(pm.response.status).to.equal(\"OK\")",
									"});",
									"",
									"pm.test(\"Assert first name is Sanna\", ()=>{",
									"    var jsonResponse = pm.response.json()",
									"    pm.expect(jsonResponse[4].email).to.eql(\"Sanna@gmail.com\")",
									"});",
									"",
									"pm.test(\"Check if Sannachittuu is present in the response\", ()=>{",
									"    pm.expect(pm.response.text()).to.include(\"Sannachittuu\")",
									"});",
									"",
									"// below code wrote using snippets ",
									"pm.test(\"Check if id 7 is present\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData[6].id).to.eql(\"7\");",
									"});",
									"",
									"pm.test(\"Response time is less than 200ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(200);",
									"});",
									"",
									"pm.test(\"Assert firt name is Shreya\", ()=>{",
									"    var jsonResponse = pm.response.json()",
									"    pm.expect(jsonResponse[1].first_name).to.equal(\"Shreya\")",
									"})",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Body matches string\", function () {",
									"    pm.expect(pm.response.text()).to.include(\"string_you_want_to_search\");",
									"});"
								],
